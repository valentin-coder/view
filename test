WITH exp AS (
    SELECT 'T01' t, 900000001 f, 'CORE001C' r, 1 e FROM DUAL UNION ALL
    SELECT 'T02', 900000001, 'CORE002',  0 FROM DUAL UNION ALL
    SELECT 'T03', 900000002, 'CORE001C', 0 FROM DUAL UNION ALL
    SELECT 'T04', 900000002, 'CORE002',  1 FROM DUAL UNION ALL
    SELECT 'T05', 900000003, 'CORE003',  1 FROM DUAL UNION ALL
    SELECT 'T06', 900000050, 'CORE003',  0 FROM DUAL UNION ALL
    SELECT 'T07', 900000005, 'CORE039',  1 FROM DUAL UNION ALL
    SELECT 'T08', 900000050, 'CORE039',  0 FROM DUAL UNION ALL
    SELECT 'T09', 900000006, 'CORE143',  1 FROM DUAL UNION ALL
    SELECT 'T10', 900000007, 'CORE143',  1 FROM DUAL UNION ALL
    SELECT 'T11', 900000008, 'CORE144',  1 FROM DUAL UNION ALL
    SELECT 'T12', 900000009, 'CORE144',  1 FROM DUAL UNION ALL
    SELECT 'T13', 900000010, 'CORE164',  1 FROM DUAL UNION ALL
    SELECT 'T14', 900000011, 'CORE164',  0 FROM DUAL UNION ALL
    SELECT 'T15', 900000012, 'LAFO083',  1 FROM DUAL UNION ALL
    SELECT 'T16', 900000012, 'LAFO084',  1 FROM DUAL UNION ALL
    SELECT 'T17', 900000013, 'LAFO095',  1 FROM DUAL UNION ALL
    SELECT 'T18', 900000050, 'LAFO095',  0 FROM DUAL UNION ALL
    SELECT 'T19', 900000014, 'LAFO081',  1 FROM DUAL UNION ALL
    SELECT 'T20', 900000016, 'LAFO082',  1 FROM DUAL UNION ALL
    SELECT 'T21', 900000018, 'RDEV009',  1 FROM DUAL UNION ALL
    SELECT 'T22', 900000019, 'RDEV011',  1 FROM DUAL UNION ALL
    SELECT 'T23', 900000020, 'RDEV026',  1 FROM DUAL UNION ALL
    SELECT 'T24', 900000022, 'RDEV027',  1 FROM DUAL UNION ALL
    SELECT 'T25', 900000024, 'AHMM017',  1 FROM DUAL UNION ALL
    SELECT 'T26', 900000025, 'AHMM018',  1 FROM DUAL UNION ALL
    SELECT 'T27', 900000026, 'AHMM020',  1 FROM DUAL UNION ALL
    SELECT 'T28', 900000026, 'AHMM022',  1 FROM DUAL UNION ALL
    SELECT 'T29', 900000027, 'AHMM040',  1 FROM DUAL UNION ALL
    SELECT 'T30', 900000028, 'AHMM037',  1 FROM DUAL UNION ALL
    SELECT 'T31', 900000030, 'AHMM038',  1 FROM DUAL UNION ALL
    SELECT 'T32', 900000032, 'VINY006',  1 FROM DUAL UNION ALL
    SELECT 'T33', 900000032, 'VINY008',  1 FROM DUAL UNION ALL
    SELECT 'T34', 900000033, 'VINY025',  1 FROM DUAL UNION ALL
    SELECT 'T35', 900000034, 'VINY026',  1 FROM DUAL UNION ALL
    SELECT 'T36', 900000035, 'VINY027',  1 FROM DUAL UNION ALL
    SELECT 'T37', 900000036, 'VINY029',  1 FROM DUAL UNION ALL
    SELECT 'T38', 900000050, 'VINY029',  0 FROM DUAL
),
act AS (
    SELECT FARM_ID,
           CORE001C, CORE002, CORE003, CORE039, CORE143, CORE144, CORE164,
           LAFO081, LAFO082, LAFO083, LAFO084, LAFO095,
           RDEV009, RDEV011, RDEV026, RDEV027,
           AHMM017, AHMM018, AHMM020, AHMM022, AHMM037, AHMM038, AHMM040,
           VINY006, VINY008, VINY025, VINY026, VINY027, VINY029
    FROM VW_VAL_CROSS_TABLE_FULL
    WHERE FARM_ID BETWEEN 900000001 AND 900000050
)
SELECT exp.t AS teszt, exp.f AS farm_id, exp.r AS szabaly, exp.e AS vart,
       CASE exp.r
           WHEN 'CORE001C' THEN act.CORE001C WHEN 'CORE002' THEN act.CORE002
           WHEN 'CORE003' THEN act.CORE003   WHEN 'CORE039' THEN act.CORE039
           WHEN 'CORE143' THEN act.CORE143   WHEN 'CORE144' THEN act.CORE144
           WHEN 'CORE164' THEN act.CORE164
           WHEN 'LAFO081' THEN act.LAFO081   WHEN 'LAFO082' THEN act.LAFO082
           WHEN 'LAFO083' THEN act.LAFO083   WHEN 'LAFO084' THEN act.LAFO084
           WHEN 'LAFO095' THEN act.LAFO095
           WHEN 'RDEV009' THEN act.RDEV009   WHEN 'RDEV011' THEN act.RDEV011
           WHEN 'RDEV026' THEN act.RDEV026   WHEN 'RDEV027' THEN act.RDEV027
           WHEN 'AHMM017' THEN act.AHMM017   WHEN 'AHMM018' THEN act.AHMM018
           WHEN 'AHMM020' THEN act.AHMM020   WHEN 'AHMM022' THEN act.AHMM022
           WHEN 'AHMM037' THEN act.AHMM037   WHEN 'AHMM038' THEN act.AHMM038
           WHEN 'AHMM040' THEN act.AHMM040
           WHEN 'VINY006' THEN act.VINY006   WHEN 'VINY008' THEN act.VINY008
           WHEN 'VINY025' THEN act.VINY025   WHEN 'VINY026' THEN act.VINY026
           WHEN 'VINY027' THEN act.VINY027   WHEN 'VINY029' THEN act.VINY029
       END AS tenyleges,
       CASE WHEN CASE exp.r
           WHEN 'CORE001C' THEN act.CORE001C WHEN 'CORE002' THEN act.CORE002
           WHEN 'CORE003' THEN act.CORE003   WHEN 'CORE039' THEN act.CORE039
           WHEN 'CORE143' THEN act.CORE143   WHEN 'CORE144' THEN act.CORE144
           WHEN 'CORE164' THEN act.CORE164
           WHEN 'LAFO081' THEN act.LAFO081   WHEN 'LAFO082' THEN act.LAFO082
           WHEN 'LAFO083' THEN act.LAFO083   WHEN 'LAFO084' THEN act.LAFO084
           WHEN 'LAFO095' THEN act.LAFO095
           WHEN 'RDEV009' THEN act.RDEV009   WHEN 'RDEV011' THEN act.RDEV011
           WHEN 'RDEV026' THEN act.RDEV026   WHEN 'RDEV027' THEN act.RDEV027
           WHEN 'AHMM017' THEN act.AHMM017   WHEN 'AHMM018' THEN act.AHMM018
           WHEN 'AHMM020' THEN act.AHMM020   WHEN 'AHMM022' THEN act.AHMM022
           WHEN 'AHMM037' THEN act.AHMM037   WHEN 'AHMM038' THEN act.AHMM038
           WHEN 'AHMM040' THEN act.AHMM040
           WHEN 'VINY006' THEN act.VINY006   WHEN 'VINY008' THEN act.VINY008
           WHEN 'VINY025' THEN act.VINY025   WHEN 'VINY026' THEN act.VINY026
           WHEN 'VINY027' THEN act.VINY027   WHEN 'VINY029' THEN act.VINY029
       END = exp.e THEN 'PASS' ELSE 'FAIL' END AS eredmeny
FROM exp
JOIN act ON act.FARM_ID = exp.f
ORDER BY exp.t;

