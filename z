CREATE TABLE MO26E.RULE_MESSAGES (
    RULE_ID        VARCHAR2(30) PRIMARY KEY,
    ERROR_TYPE     VARCHAR2(10),
    ERROR_MESSAGE  VARCHAR2(4000)
);

SELECT ERROR_TYPE, COUNT(*) FROM MO26E.RULE_MESSAGES GROUP BY ERROR_TYPE;
-- Várhatóan: Error ~X db, Info ~Y db, összesen ~290 körül

CREATE OR REPLACE VIEW VW_VAL_BY_IDENTIFIER_FULL AS
SELECT v.FARM_ID,
       v.VAL_RULE_ID,
       m.ERROR_TYPE    AS VAL_SEVERITY,
       m.ERROR_MESSAGE AS VAL_ERROR_MESSAGE
FROM VW_VAL_BY_IDENTIFIER_FULL v
LEFT JOIN MO26E.RULE_MESSAGES m
       ON UPPER(m.RULE_ID) = UPPER(v.VAL_RULE_ID);

CREATE OR REPLACE VIEW VW_VAL_BY_RULE_FULL AS
SELECT v.VAL_RULE_ID,
       m.ERROR_TYPE    AS VAL_SEVERITY,
       m.ERROR_MESSAGE AS VAL_ERROR_MESSAGE,
       v.FARM_ID
FROM VW_VAL_BY_IDENTIFIER_FULL v
LEFT JOIN MO26E.RULE_MESSAGES m
       ON UPPER(m.RULE_ID) = UPPER(v.VAL_RULE_ID);

-- A) Van-e olyan aktív szabály a mátrixban, amihez NINCS üzenet?
SELECT DISTINCT v.VAL_RULE_ID
FROM VW_VAL_BY_IDENTIFIER_FULL v
LEFT JOIN MO26E.RULE_MESSAGES m ON UPPER(m.RULE_ID) = UPPER(v.VAL_RULE_ID)
WHERE m.RULE_ID IS NULL;

-- B) Van-e olyan üzenet az Excelből, aminek NINCS oszlopa a mátrixban?
--    (Ezeknek a 15+2 nyitott/kihagyott tételnek kell lenniük: LAFO042..., RDEV008,
--     CORE022, CORE023, CORE127, CORE169 stb. — ha más is felbukkan, az jelzés!)
SELECT m.RULE_ID
FROM MO26E.RULE_MESSAGES m
LEFT JOIN user_tab_columns c
       ON c.table_name = 'VW_VAL_CROSS_TABLE_FULL'
      AND c.column_name = UPPER(m.RULE_ID)
WHERE c.column_name IS NULL
ORDER BY m.RULE_ID;
