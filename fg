    SELECT HLD_ID AS FARM_ID,
           COUNT(DISTINCT STRA_ID_AHMM) OVER (PARTITION BY PSU_AHMM) AS distinct_strata
    FROM VW_BASE_ENRICHED WHERE PSU_AHMM IS NOT NULL
)
WHERE distinct_strata > 1;

CREATE OR REPLACE VIEW VW_VAL_AHMM038 AS
SELECT FARM_ID, 'AHMM038' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'There should not be 2 records with the same SSU and different PSU or different strata' AS VAL_ERROR_MESSAGE
FROM (
    SELECT HLD_ID AS FARM_ID,
           COUNT(DISTINCT PSU_AHMM) OVER (PARTITION BY SSU_AHMM) AS distinct_psu,
           COUNT(DISTINCT STRA_ID_AHMM) OVER (PARTITION BY SSU_AHMM) AS distinct_strata
    FROM VW_BASE_ENRICHED WHERE SSU_AHMM IS NOT NULL
)
WHERE distinct_psu > 1 OR distinct_strata > 1;


-- ---------------------------------------------------------------------
-- 13. VINY006, VINY008 — LIST_VINY halmaz-szabályok
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_VINY006 AS
SELECT HLD_ID AS FARM_ID, 'VINY006' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'All holdings without VINY module data shall have all data fields and sampling design fields for the VINY module null' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE EXTPOL_FACT1_VINY IS NULL
  AND (TIME_PERIOD_VINY IS NOT NULL OR W1100 IS NOT NULL OR W1100_Y_LT3 IS NOT NULL
    OR W1100_Y_3T9 IS NOT NULL OR W1100_Y_10T19 IS NOT NULL OR W1100_Y_20T29 IS NOT NULL
    OR W1100_Y_GE30 IS NOT NULL OR WINE_VAR_NR IS NOT NULL
    OR STRA_IDF_VINY <> '_Z' OR PSUF_VINY <> '_Z' OR SSUF_VINY <> '_Z' OR OSU_SF1_VINY <> '_Z');

CREATE OR REPLACE VIEW VW_VAL_VINY008 AS
SELECT HLD_ID AS FARM_ID, 'VINY008' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'All holdings with VINY module data should have at least the first two extrapolation factors for the module completed' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE (W1100 IS NOT NULL OR WINE_VAR_NR IS NOT NULL)
  AND EXTPOL_FACT1_VINY IS NULL;


-- ---------------------------------------------------------------------
-- 14. VINY022, VINY023 — rekord-pár
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_VINY022 AS
SELECT FARM_ID, 'VINY022' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'There should not be 2 records with the same PSU and different strata' AS VAL_ERROR_MESSAGE
FROM (
    SELECT HLD_ID AS FARM_ID,
           COUNT(DISTINCT STRA_ID_VINY) OVER (PARTITION BY PSU_VINY) AS distinct_strata
    FROM VW_BASE_ENRICHED WHERE PSU_VINY IS NOT NULL
)
WHERE distinct_strata > 1;

CREATE OR REPLACE VIEW VW_VAL_VINY023 AS
SELECT FARM_ID, 'VINY023' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'There should not be 2 records with the same SSU and different PSU or different strata' AS VAL_ERROR_MESSAGE
FROM (
    SELECT HLD_ID AS FARM_ID,
           COUNT(DISTINCT PSU_VINY) OVER (PARTITION BY SSU_VINY) AS distinct_psu,
           COUNT(DISTINCT STRA_ID_VINY) OVER (PARTITION BY SSU_VINY) AS distinct_strata
    FROM VW_BASE_ENRICHED WHERE SSU_VINY IS NOT NULL
)
WHERE distinct_psu > 1 OR distinct_strata > 1;


-- ---------------------------------------------------------------------
-- 15. VINY025 — javított oszlopnevek
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_VINY025 AS
SELECT HLD_ID AS FARM_ID, 'VINY025' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'The total area of grapes for wine must be higher or equal to the sum of areas of grapes for wine in different age classes' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE NOT (NVL(W1100,0) >= NVL(W1100_Y_LT3,0) + NVL(W1100_Y_3T9,0) + NVL(W1100_Y_10T19,0)
                          + NVL(W1100_Y_20T29,0) + NVL(W1100_Y_GE30,0));


-- ---------------------------------------------------------------------
-- 16. VINY026, VINY027 — elgépelés javítása (TIME_PEROD -> TIME_PERIOD_VINY)
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_VINY026 AS
SELECT HLD_ID AS FARM_ID, 'VINY026' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'The total area of grapes for wine must be greater or equal to the total outdoor area of grapes for wine' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE NVL(TIME_PERIOD,0) = NVL(TIME_PERIOD_VINY,0)
  AND NOT (NVL(W1100,0) >= NVL(W1100T,0));

CREATE OR REPLACE VIEW VW_VAL_VINY027 AS
SELECT HLD_ID AS FARM_ID, 'VINY027' AS VAL_RULE_ID, 'Info' AS VAL_SEVERITY,
       'The total area of grapes for wine must be greater or equal to the total outdoor area of grapes for wine (different reference years)' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE NVL(TIME_PERIOD,0) <> NVL(TIME_PERIOD_VINY,0)
  AND NOT (NVL(W1100,0) >= NVL(W1100T,0));


-- ---------------------------------------------------------------------
-- 17. VINY028, VINY029 — VIN2026 kapcsolt tábla (kulcs: HLD_ID)
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_VINY028 AS
SELECT v.HLD_ID AS FARM_ID, 'VINY028' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'The holding ID in the varieties table must exist in the microdata table when the holding is relevant for the vineyards module' AS VAL_ERROR_MESSAGE
FROM "MO26E"."VIN2026" v
WHERE v.HLD_ID IS NOT NULL
  AND NOT EXISTS (
      SELECT 1 FROM VW_BASE_ENRICHED c
      WHERE c.HLD_ID = v.HLD_ID AND c.EXTPOL_FACT1_VINY IS NOT NULL
  );

CREATE OR REPLACE VIEW VW_VAL_VINY029 AS
SELECT c.HLD_ID AS FARM_ID, 'VINY029' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'The total number of lines for the HLD_ID in the varieties table must equal the number of variables indicated in the microdata' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED c
JOIN (
    SELECT HLD_ID, COUNT(*) AS var_count
    FROM "MO26E"."VIN2026"
    WHERE HLD_ID IS NOT NULL
    GROUP BY HLD_ID
) v ON v.HLD_ID = c.HLD_ID
WHERE v.var_count <> c.WINE_VAR_NR;


