CREATE OR REPLACE VIEW VW_VAL_CORE003 AS
SELECT b.HLD_ID AS FARM_ID, 'CORE003' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'There are duplicates in the holding ID' AS VAL_ERROR_MESSAGE
FROM (
    SELECT HLD_ID FROM VW_BASE_ENRICHED GROUP BY HLD_ID HAVING COUNT(*) > 1
) dup
JOIN VW_BASE_ENRICHED b ON b.HLD_ID = dup.HLD_ID;


-- ---------------------------------------------------------------------
-- B) VIN2026 kapcsolt szabályok (kulcs: HLD_ID)
-- ---------------------------------------------------------------------

CREATE OR REPLACE VIEW VW_VAL_VINY028 AS
SELECT v.HLD_ID AS FARM_ID, 'VINY028' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'The holding ID in the varieties table must exist in the microdata table when the holding is relevant for the vineyards module' AS VAL_ERROR_MESSAGE
FROM "MO26E"."VIN2026" v
WHERE v.HLD_ID IS NOT NULL
  AND NOT EXISTS (
      SELECT 1 FROM VW_BASE_ENRICHED c
      WHERE c.HLD_ID = v.HLD_ID AND c.EXTPOL_FACT1_VINY IS NOT NULL
  );

CREATE OR REPLACE VIEW VW_VAL_VINY029 AS
SELECT c.HLD_ID AS FARM_ID, 'VINY029' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'The total number of lines for the HLD_ID in the varieties table must equal the number of variables indicated in the microdata' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED c
JOIN (
    SELECT HLD_ID, COUNT(*) AS var_count
    FROM "MO26E"."VIN2026"
    WHERE HLD_ID IS NOT NULL
    GROUP BY HLD_ID
) v ON v.HLD_ID = c.HLD_ID
WHERE v.var_count <> c.WINE_VAR_NR;


