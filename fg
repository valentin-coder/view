UNION ALL SELECT 'VINY030', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE VINY030 = 1
ORDER BY RULE;

-- Ellenőrzési szempontok az eredményhez:
--  - Ha egy szabály hibaszáma == a teljes gazdaságszám -> valószínűleg
--    a feltétel fordítva van (pl. NOT hiányzik vagy fölösleges).
--  - Ha egy szabály hibaszáma == 0, de logikailag várható lenne néhány
--    hiba (pl. CORE003 duplikáció), érdemes manuálisan rákeresni.
--  - LAFO083 / RDEV009 / AHMM020 / VINY006 stb. jellemzően kevés hibát
--    kell adjanak (csak akkor jeleznek, ha egy modul-adat inkonzisztens
--    az EXTPOL_FACT-tal) -- ha ezek nagy számot adnak, a modul-mező-lista
--    lefedettsége gyanús.


-- ---------------------------------------------------------------------
-- 5. KERESZT-ELLENŐRZÉS: a CORE039 új szabály és a régi CORE145
--    logikailag rokon (mindkettő UAA vs. organikus terület) --
--    nem szabad, hogy egymásnak ellentmondjanak ugyanarra a sorra.
-- ---------------------------------------------------------------------

SELECT c.FARM_ID, c.CORE039, c.CORE145
FROM VW_VAL_CROSS_TABLE_FULL c
WHERE (c.CORE039 = 1 AND c.CORE145 = 0)
   OR (c.CORE039 = 0 AND c.CORE145 = 1);
-- Ha itt sok sor jön vissza, érdemes megnézni miért tér el a két
-- logikailag hasonló szabály ugyanarra a gazdaságra -- ez segít
-- kiszűrni, ha az egyikben elírás van (pl. >= helyett <=).


-- ---------------------------------------------------------------------
-- 6. AHMM017/018 KERESZT-ELLENŐRZÉS a DECODE-transzformációval
--    Ellenőrizd, hogy a VW_BASE_ENRICHED-ben számolt *_NUM oszlopok
--    valóban a várt tartományban (0-100) vannak-e.
-- ---------------------------------------------------------------------

SELECT
    MIN(INC_BC_LE4H_NUM) AS MIN_VAL, MAX(INC_BC_LE4H_NUM) AS MAX_VAL,
    COUNT(CASE WHEN INC_BC_LE4H_PC IS NOT NULL AND INC_BC_LE4H_NUM IS NULL THEN 1 END) AS UNMAPPED_CODES
FROM VW_BASE_ENRICHED;
-- ELVÁRÁS: MIN >= 0, MAX <= 100, UNMAPPED_CODES = 0.
-- Ha UNMAPPED_CODES > 0, van olyan INC_BC_LE4H_PC érték a táblában,
-- amit a DECODE lista nem fed le (pl. új kód, amit nem ismertünk).
-- Ha ez előfordul, futtasd le, hogy lásd melyik kód hiányzik:

SELECT DISTINCT INC_BC_LE4H_PC
FROM VW_BASE_ENRICHED
WHERE INC_BC_LE4H_PC IS NOT NULL AND INC_BC_LE4H_NUM IS NULL;


-- ---------------------------------------------------------------------
-- 7. LAFO083/084/095 LOGIKAI KOMPLEMENTARITÁS
--    083 (van modul-adat, de EXTPOL hiányzik) és 084 (nincs EXTPOL,
--    minden nullnak kéne lennie) és 095 (van EXTPOL, minden kitöltve
--    kell legyen) -- egy adott gazdaságra legfeljebb az egyik lehet
--    igaz egyszerre (083 és 095 kizárják egymást; 084 és 095 is).
-- ---------------------------------------------------------------------

SELECT FARM_ID, LAFO083, LAFO084, LAFO095
FROM VW_VAL_CROSS_TABLE_FULL
WHERE (LAFO083 = 1 AND LAFO095 = 1)
   OR (LAFO084 = 1 AND LAFO095 = 1)
   OR (LAFO083 = 1 AND LAFO084 = 1);
-- ELVÁRÁS: 0 sor. Ha van találat, az logikai ellentmondást jelez
-- (pl. EXTPOL_FACT1_LAFO NULL-sága körüli feltétel valahol hibás).


-- ---------------------------------------------------------------------
-- 8. VIN2026 REFERENCIÁLIS INTEGRITÁS ÖSSZEFOGLALÓ
-- ---------------------------------------------------------------------

SELECT
    (SELECT COUNT(*) FROM "MO26E"."VIN2026") AS VIN2026_TOTAL_ROWS,
    (SELECT COUNT(DISTINCT HLD_ID) FROM "MO26E"."VIN2026") AS VIN2026_DISTINCT_HLD,
    (SELECT COUNT(*) FROM VW_VAL_VINY028) AS VINY028_VIOLATIONS,
    (SELECT COUNT(*) FROM VW_VAL_VINY029) AS VINY029_VIOLATIONS
FROM DUAL;


-- ---------------------------------------------------------------------
-- 9. TELJES ÖSSZESÍTÉS — a végső mátrix méret-ellenőrzése
-- ---------------------------------------------------------------------

SELECT
    (SELECT COUNT(*) FROM VW_BASE_ENRICHED) AS TOTAL_FARMS,
    (SELECT COUNT(DISTINCT VAL_RULE_ID) FROM VW_VAL_BY_IDENTIFIER_FULL) AS DISTINCT_RULES_WITH_HITS,
    (SELECT COUNT(*) FROM VW_VAL_BY_IDENTIFIER_FULL) AS TOTAL_VIOLATION_ROWS,
    (SELECT COUNT(DISTINCT FARM_ID) FROM VW_VAL_BY_IDENTIFIER_FULL) AS FARMS_WITH_AT_LEAST_ONE_ERROR
FROM DUAL;