-- =====================================================================
-- IFS 2026 VALIDATION VIEWS — TELJES KIEGÉSZÍTÉS
-- Alaptábla: "MO26E"."MO26_EUF_ALL_EREDETI"
-- Kapcsolt tábla: "MO26E"."VIN2026" (kulcs: HLD_ID)
-- Ehhez UNION ALL-lal hozzáfűzhető a már meglévő
-- VW_VAL_BY_IDENTIFIER (244 szabály).
--
-- Ma megoldott: 34 önálló validációs szabály
-- Segéd-transzformáció (nem önálló szabály, VW_BASE_ENRICHED-ben): 13
-- Függőben (email szükséges): 15
--   - CORE169, CORE023 (külső referenciatábla)
--   - LAFO042,043,044,045,052,053,054,090,091,092 (hiányzó NOGA/*_NFAM mezők)
--   - RDEV008,028,029 (elavult/átszámozott mezőnevek)
-- =====================================================================


-- ---------------------------------------------------------------------
-- 0. ENRICHMENT VIEW — kötelező alap minden más view-hoz
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_BASE_ENRICHED AS
SELECT
    t.*,

    -- CORE114
    (NVL(A2010,0)*0.4 + NVL(A2020,0)*0.7 + NVL(A2130,0)*1 + NVL(A2230,0)*0.8
     + NVL(A2300F,0)*1 + NVL(A2300G,0)*0.8
     + NVL(A4100,0)*0.1 + NVL(A4200,0)*0.1
     + NVL(A3110,0)*0.027 + NVL(A3120,0)*0.5 + NVL(A3130,0)*0.3
     + NVL(A5140,0)*0.007 + NVL(A5110O,0)*0.014 + NVL(A5230,0)*0.03
     + NVL(A5210,0)*0.01 + NVL(A5220,0)*0.02 + NVL(A5410,0)*0.35
     + NVL(A5240_5300,0)*0.001 + NVL(A6111,0)*0.02) AS LIVESTOCK_LSU,

    -- CORE115
    NVL(t.UAAT,0) + NVL(t.UAAS,0) AS UAA_CALC,

    -- CORE116
    NVL(t.ARAT,0) + NVL(t.ARA09S,0) + NVL(t.V0000_S0000S,0) + NVL(t.N0000S,0) AS ARA_CALC,

    -- LAFO086 / LAFO087
    CASE t.WH_MAN_AWU_PC
        WHEN '_Z' THEN 0 WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25
        WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 WHEN 'PC100' THEN 100
        ELSE NULL END AS WH_MAN_AWU_NUM,
    CASE t.WH_HLD_AWU_PC
        WHEN '_Z' THEN 0 WHEN 'PC0' THEN 0 WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25
        WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 WHEN 'PC100' THEN 100
        ELSE NULL END AS WH_HLD_AWU_NUM,

    -- RDEV030-032
    CASE t.A6210 WHEN '0' THEN 0 WHEN '1' THEN 1 ELSE NULL END AS A6210_NUM,
    CASE t.A6010 WHEN '0' THEN 0 WHEN '1' THEN 1 ELSE NULL END AS A6010_NUM,
    CASE t.A0030 WHEN '0' THEN 0 WHEN '1' THEN 1 ELSE NULL END AS A0030_NUM,

    -- AHMM010-016
    CASE t.INC_BC_LE4H_PC WHEN 'PC100' THEN 100 WHEN 'PC0' THEN 0 WHEN '_Z' THEN 0
        WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25 WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 ELSE NULL END AS INC_BC_LE4H_NUM,
    CASE t.INC_BC_GT4H_PC WHEN 'PC100' THEN 100 WHEN 'PC0' THEN 0 WHEN '_Z' THEN 0
        WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25 WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 ELSE NULL END AS INC_BC_GT4H_NUM,
    CASE t.NINC_BC_PC WHEN 'PC100' THEN 100 WHEN 'PC0' THEN 0 WHEN '_Z' THEN 0
        WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25 WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 ELSE NULL END AS NINC_BC_NUM,
    CASE t.INC_BSTH_PC WHEN 'PC100' THEN 100 WHEN 'PC0' THEN 0 WHEN '_Z' THEN 0
        WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25 WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 ELSE NULL END AS INC_BSTH_NUM,
    CASE t.INC_BSTS_PC WHEN 'PC100' THEN 100 WHEN 'PC0' THEN 0 WHEN '_Z' THEN 0
        WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25 WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 ELSE NULL END AS INC_BSTS_NUM,
    CASE t.INJ_SOL_PC WHEN 'PC100' THEN 100 WHEN 'PC0' THEN 0 WHEN '_Z' THEN 0
        WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25 WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 ELSE NULL END AS INJ_SOL_NUM,
    CASE t.INJ_DPCL_PC WHEN 'PC100' THEN 100 WHEN 'PC0' THEN 0 WHEN '_Z' THEN 0
        WHEN 'PC1T24' THEN 1 WHEN 'PC25T49' THEN 25 WHEN 'PC50T74' THEN 50 WHEN 'PC75T99' THEN 75 ELSE NULL END AS INJ_DPCL_NUM

FROM "MO26E"."MO26_EUF_ALL_EREDETI" t;


-- ---------------------------------------------------------------------
-- 1. CORE001c, CORE002 — fájlnév-metaadat
--    Paraméter-tábla javasolt megoldás (lásd lent), bind változó helyett
-- ---------------------------------------------------------------------
-- Egyszeri létrehozás és feltöltés, ha még nincs meg:
-- CREATE TABLE MO26E.LOAD_PARAMS (FILENAME_YEAR VARCHAR2(4), FILENAME_COUNTRY VARCHAR2(2));
-- INSERT INTO MO26E.LOAD_PARAMS VALUES ('2026', 'HU');

CREATE OR REPLACE VIEW VW_VAL_CORE001C AS
SELECT HLD_ID AS FARM_ID, 'CORE001c' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'Time period needs to be consistent with the filename' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE NOT (TIME_PERIOD = (SELECT FILENAME_YEAR FROM MO26E.LOAD_PARAMS));

CREATE OR REPLACE VIEW VW_VAL_CORE002 AS
SELECT HLD_ID AS FARM_ID, 'CORE002' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'REF_AREA needs to be consistent with file name' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE (SELECT FILENAME_COUNTRY FROM MO26E.LOAD_PARAMS) <> 'C1'
  AND NOT (REF_AREA = (SELECT FILENAME_COUNTRY FROM MO26E.LOAD_PARAMS));


-- ---------------------------------------------------------------------
-- 2. CORE003 — duplikáció
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_CORE003 AS
SELECT b.HLD_ID AS FARM_ID, 'CORE003' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'There are duplicates in the holding ID' AS VAL_ERROR_MESSAGE
FROM (
    SELECT HLD_ID FROM VW_BASE_ENRICHED GROUP BY HLD_ID HAVING COUNT(*) > 1
) dup
JOIN VW_BASE_ENRICHED b ON b.HLD_ID = dup.HLD_ID;


-- ---------------------------------------------------------------------
-- 3. CORE039 — Utilised Agricultural Area (UAA) vs organic subcomponents
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_CORE039 AS
SELECT HLD_ID AS FARM_ID, 'CORE039' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'Utilised Agricultural Area (ha) is not >= SUM ha of (Farming system: Organic farming certified + Conversion to organic farming)' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE NOT (UAA_CALC >= NVL(UAAXK0000_ORGF,0) + NVL(UAAXK0000_ORGU,0));


-- ---------------------------------------------------------------------
-- 4. CORE143, CORE144 — rekord-pár egyezőség
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_CORE143 AS
SELECT FARM_ID, 'CORE143' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'There should not be 2 records with the same PSU and different strata' AS VAL_ERROR_MESSAGE
FROM (
    SELECT HLD_ID AS FARM_ID,
           COUNT(DISTINCT STRA_ID_CORE) OVER (PARTITION BY PSU_CORE) AS distinct_strata
    FROM VW_BASE_ENRICHED WHERE PSU_CORE IS NOT NULL
)
WHERE distinct_strata > 1;

CREATE OR REPLACE VIEW VW_VAL_CORE144 AS
SELECT FARM_ID, 'CORE144' AS VAL_RULE_ID, 'Error' AS VAL_SEVERITY,
       'There should not be 2 records with the same SSU and different PSU or different strata' AS VAL_ERROR_MESSAGE
FROM (
    SELECT HLD_ID AS FARM_ID,
           COUNT(DISTINCT PSU_CORE) OVER (PARTITION BY SSU_CORE) AS distinct_psu,
           COUNT(DISTINCT STRA_ID_CORE) OVER (PARTITION BY SSU_CORE) AS distinct_strata
    FROM VW_BASE_ENRICHED WHERE SSU_CORE IS NOT NULL
)
WHERE distinct_psu > 1 OR distinct_strata > 1;


-- ---------------------------------------------------------------------
-- 5. CORE164 — frame extension threshold
-- ---------------------------------------------------------------------
CREATE OR REPLACE VIEW VW_VAL_CORE164 AS
SELECT HLD_ID AS FARM_ID, 'CORE164' AS VAL_RULE_ID, 'Info' AS VAL_SEVERITY,
       'The holding is below all thresholds and is not a part of the frame extension' AS VAL_ERROR_MESSAGE
FROM VW_BASE_ENRICHED
WHERE (UAA_CALC < 5 AND ARA_CALC < 2 AND NVL(R1000T,0) < 0.5 AND NVL(V0000_S0000T,0) < 0.5
   AND (NVL(I5000T,0) + NVL(N0000T,0) + NVL(E0000T,0) + NVL(L0000T,0)) < 0.2
   AND (NVL(F0000T,0) + NVL(T0000T,0) + NVL(PECR9_H9000T,0)) < 0.3
   AND NVL(W1000T,0) < 0.1 AND NVL(O1000T,0) < 0.3
   AND NVL(UAAS,0) < 0.01 AND NVL(U1000,0) < 0.01 AND LIVESTOCK_LSU < 1.7)
  AND NOT (HLD_FEF = 1);


