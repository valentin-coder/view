UNION ALL SELECT 'CORE039', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE CORE039 = 1
UNION ALL SELECT 'CORE143', COUNT(*) FROM VW_VAL_CORE143
UNION ALL SELECT 'CORE144', COUNT(*) FROM VW_VAL_CORE144
UNION ALL SELECT 'CORE164', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE CORE164 = 1
UNION ALL SELECT 'LAFO081', COUNT(*) FROM VW_VAL_LAFO081
UNION ALL SELECT 'LAFO082', COUNT(*) FROM VW_VAL_LAFO082
UNION ALL SELECT 'LAFO083', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE LAFO083 = 1
UNION ALL SELECT 'LAFO084', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE LAFO084 = 1
UNION ALL SELECT 'LAFO095', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE LAFO095 = 1
UNION ALL SELECT 'RDEV009', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE RDEV009 = 1
UNION ALL SELECT 'RDEV011', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE RDEV011 = 1
UNION ALL SELECT 'RDEV026', COUNT(*) FROM VW_VAL_RDEV026
UNION ALL SELECT 'RDEV027', COUNT(*) FROM VW_VAL_RDEV027
UNION ALL SELECT 'AHMM017', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE AHMM017 = 1
UNION ALL SELECT 'AHMM018', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE AHMM018 = 1
UNION ALL SELECT 'AHMM020', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE AHMM020 = 1
UNION ALL SELECT 'AHMM022', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE AHMM022 = 1
UNION ALL SELECT 'AHMM037', COUNT(*) FROM VW_VAL_AHMM037
UNION ALL SELECT 'AHMM038', COUNT(*) FROM VW_VAL_AHMM038
UNION ALL SELECT 'AHMM040', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE AHMM040 = 1
UNION ALL SELECT 'VINY006', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE VINY006 = 1
UNION ALL SELECT 'VINY008', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE VINY008 = 1
UNION ALL SELECT 'VINY022', COUNT(*) FROM VW_VAL_VINY022
UNION ALL SELECT 'VINY023', COUNT(*) FROM VW_VAL_VINY023
UNION ALL SELECT 'VINY025', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE VINY025 = 1
UNION ALL SELECT 'VINY026', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE VINY026 = 1
UNION ALL SELECT 'VINY027', COUNT(*) FROM VW_VAL_CROSS_TABLE_FULL WHERE VINY027 = 1
UNION ALL SELECT 'VINY028', COUNT(*) FROM VW_VAL_VINY028
