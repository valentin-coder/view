-- ---------------------------------------------------------------------
-- 1. STRUKTURÁLIS ELLENŐRZÉS
--    Létezik-e minden view, és van-e bennük érvénytelen objektum
-- ---------------------------------------------------------------------

SELECT object_name, object_type, status
FROM user_objects
WHERE object_name IN (
    'VW_BASE_ENRICHED', 'VW_VAL_CROSS_TABLE_FULL',
    'VW_VAL_CORE003', 'VW_VAL_CORE143', 'VW_VAL_CORE144',
    'VW_VAL_LAFO081', 'VW_VAL_LAFO082',
    'VW_VAL_RDEV026', 'VW_VAL_RDEV027',
    'VW_VAL_AHMM037', 'VW_VAL_AHMM038',
    'VW_VAL_VINY022', 'VW_VAL_VINY023',
    'VW_VAL_VINY028', 'VW_VAL_VINY029',
    'VW_VAL_BY_IDENTIFIER_FULL', 'VW_VAL_BY_RULE_FULL'
)
ORDER BY object_name;
-- ELVÁRÁS: minden sor STATUS = 'VALID'. Ha bármelyik 'INVALID',
-- a lefordítás sikertelen volt -- futtasd le rá:
-- SELECT text FROM user_errors WHERE name = '<VIEW_NEVE>' ORDER BY sequence;


-- ---------------------------------------------------------------------
-- 2. OSZLOPSZÁM-ELLENŐRZÉS
--    Hány szabály-oszlop van ténylegesen a kereszttáblában,
--    és ez egyezik-e a várt darabszámmal (FARM_ID nélkül)
-- ---------------------------------------------------------------------

SELECT COUNT(*) - 1 AS RULE_COLUMN_COUNT  -- -1, mert a FARM_ID nem szabály
FROM all_tab_columns
WHERE table_name = 'VW_VAL_CROSS_TABLE_FULL';
-- ELVÁRÁS: kb. 220-230 (a 2/3 részben felsorolt CASE WHEN oszlopok száma)


-- ---------------------------------------------------------------------
-- 3. NULL-BIZTONSÁGI TESZT
--    A CASE WHEN kifejezések soha nem adhatnak vissza NULL-t --
--    csak 0 vagy 1 lehet az eredmény. Ha bármelyik NULL, az azt
--    jelenti, hogy egy NVL/IS NULL lefedettség hiányzik valahol.
-- ---------------------------------------------------------------------

SELECT
    SUM(CASE WHEN CORE001 IS NULL THEN 1 ELSE 0 END) AS NULL_CORE001,
    SUM(CASE WHEN CORE039 IS NULL THEN 1 ELSE 0 END) AS NULL_CORE039,
    SUM(CASE WHEN CORE164 IS NULL THEN 1 ELSE 0 END) AS NULL_CORE164,
    SUM(CASE WHEN LAFO083 IS NULL THEN 1 ELSE 0 END) AS NULL_LAFO083,
    SUM(CASE WHEN LAFO084 IS NULL THEN 1 ELSE 0 END) AS NULL_LAFO084,
    SUM(CASE WHEN LAFO095 IS NULL THEN 1 ELSE 0 END) AS NULL_LAFO095,
    SUM(CASE WHEN RDEV009 IS NULL THEN 1 ELSE 0 END) AS NULL_RDEV009,
    SUM(CASE WHEN RDEV011 IS NULL THEN 1 ELSE 0 END) AS NULL_RDEV011,
    SUM(CASE WHEN AHMM017 IS NULL THEN 1 ELSE 0 END) AS NULL_AHMM017,
    SUM(CASE WHEN AHMM018 IS NULL THEN 1 ELSE 0 END) AS NULL_AHMM018,
    SUM(CASE WHEN AHMM020 IS NULL THEN 1 ELSE 0 END) AS NULL_AHMM020,
    SUM(CASE WHEN AHMM022 IS NULL THEN 1 ELSE 0 END) AS NULL_AHMM022,
    SUM(CASE WHEN AHMM040 IS NULL THEN 1 ELSE 0 END) AS NULL_AHMM040,
    SUM(CASE WHEN VINY006 IS NULL THEN 1 ELSE 0 END) AS NULL_VINY006,
    SUM(CASE WHEN VINY008 IS NULL THEN 1 ELSE 0 END) AS NULL_VINY008,
    SUM(CASE WHEN VINY025 IS NULL THEN 1 ELSE 0 END) AS NULL_VINY025,
    SUM(CASE WHEN VINY026 IS NULL THEN 1 ELSE 0 END) AS NULL_VINY026,
    SUM(CASE WHEN VINY027 IS NULL THEN 1 ELSE 0 END) AS NULL_VINY027,
    SUM(CASE WHEN VINY030 IS NULL THEN 1 ELSE 0 END) AS NULL_VINY030
FROM VW_VAL_CROSS_TABLE_FULL;
-- ELVÁRÁS: minden érték 0. Ha valahol nem 0, az adott szabály
-- CASE WHEN feltétele hiányos lefedettségű valamelyik NULL-mintázatra.


-- ---------------------------------------------------------------------
-- 4. HIBASZÁM-ELOSZLÁS a ma hozzáadott szabályokra
--    Ha egy szabály 0-t vagy a teljes populációt adja hibaként,
--    az gyanús -- vagy a szabály triviálisan igaz/hamis, vagy hibás.
-- ---------------------------------------------------------------------

