-- =====================================================================
-- IFS 2026 VALIDATION — 2/3: VW_VAL_CROSS_TABLE_FULL
-- MINDEN szabály itt van (274 oszlop), kivéve VINY028 (lásd 3/3).
-- =====================================================================

CREATE OR REPLACE VIEW VW_VAL_CROSS_TABLE_FULL AS
SELECT
    HLD_ID AS FARM_ID,

    -- ===== Fájlnév-paraméteres szabályok =====
    CASE WHEN NOT (TIME_PERIOD = (SELECT FILENAME_YEAR FROM MO26E.LOAD_PARAMS)) THEN 1 ELSE 0 END AS CORE001C,
    CASE WHEN (SELECT FILENAME_COUNTRY FROM MO26E.LOAD_PARAMS) <> 'C1'
          AND NOT (REF_AREA = (SELECT FILENAME_COUNTRY FROM MO26E.LOAD_PARAMS)) THEN 1 ELSE 0 END AS CORE002,

    -- ===== Duplikáció (korábban külön view) =====
    CASE WHEN HLD_CNT > 1 THEN 1 ELSE 0 END AS CORE003,

    -- ===== CORE soronkénti szabályok =====
    CASE WHEN NOT (TIME_PERIOD = 2026) THEN 1 ELSE 0 END AS CORE001,
    CASE WHEN NOT (SUBSTR(GEO_LCT, 1, 2) = REF_AREA) THEN 1 ELSE 0 END AS CORE021,
    CASE WHEN (Y_BIRTH_MAN IS NOT NULL) AND NOT (NVL(Y_BIRTH_MAN, 0) < 2009 OR NVL(Y_BIRTH_MAN, 0) > 1926) THEN 1 ELSE 0 END AS CORE024,
    CASE WHEN (Y_BIRTH_MAN IS NOT NULL) AND NOT (NVL(Y_BIRTH_MAN, 0) < NVL(Y_FARM_MAN, 0)) THEN 1 ELSE 0 END AS CORE025,
    CASE WHEN (LEG_FORM IN ('FARM_HLD', 'FARM_HLD_SPOUFAM', 'FARM_SPOU', 'FARM_FAM', 'FARM_NFAM', 'PER_LEG_NEG', 'PER_LEG_EG', 'HLD_GRP')) AND NOT (SEX_MAN <> '_Z') THEN 1 ELSE 0 END AS CORE026,
    CASE WHEN (LEG_FORM IN ('FARM_HLD', 'FARM_HLD_SPOUFAM', 'FARM_SPOU', 'FARM_FAM', 'FARM_NFAM', 'PER_LEG_NEG', 'PER_LEG_EG', 'HLD_GRP')) AND NOT (SEX_MAN IN ('M', 'F')) THEN 1 ELSE 0 END AS CORE027,
    CASE WHEN (LEG_FORM IN ('FARM_HLD', 'FARM_HLD_SPOUFAM', 'FARM_SPOU', 'FARM_FAM', 'FARM_NFAM', 'PER_LEG_NEG', 'PER_LEG_EG', 'HLD_GRP')) AND NOT (WH_MAN_AWU_PC <> '_Z') THEN 1 ELSE 0 END AS CORE028,
    CASE WHEN (LEG_FORM IN ('FARM_HLD','FARM_HLD_SPOUFAM','HLD_GRP')) AND NOT (WH_MAN_AWU_PC NOT IN ('_Z','PC0')) THEN 1 ELSE 0 END AS CORE029,
    CASE WHEN (LEG_FORM IN ('FARM_HLD', 'FARM_HLD_SPOUFAM', 'FARM_SPOU', 'FARM_FAM', 'FARM_NFAM', 'PER_LEG_NEG', 'PER_LEG_EG', 'HLD_GRP')) AND NOT (Y_FARM_MAN IS NOT NULL) THEN 1 ELSE 0 END AS CORE030,
    CASE WHEN (LEG_FORM IN ('FARM_HLD', 'FARM_HLD_SPOUFAM', 'FARM_SPOU', 'FARM_FAM', 'FARM_NFAM', 'PER_LEG_NEG', 'PER_LEG_EG', 'HLD_GRP')) AND NOT (TNG_MAN <> '_Z') THEN 1 ELSE 0 END AS CORE031,
    CASE WHEN (LEG_FORM IN ('FARM_HLD', 'FARM_HLD_SPOUFAM', 'FARM_SPOU', 'FARM_FAM', 'FARM_NFAM', 'PER_LEG_NEG', 'PER_LEG_EG', 'HLD_GRP')) AND NOT (VT_MAN_M12 <> '_Z') THEN 1 ELSE 0 END AS CORE032,
    CASE WHEN NOT (NVL(UAAT,0) = NVL(ARAT,0)+NVL(J0000T,0)+NVL(PECRT,0)+NVL(K0000T,0)) THEN 1 ELSE 0 END AS CORE038,
    CASE WHEN NOT (UAA_CALC >= NVL(UAAXK0000_ORGF,0) + NVL(UAAXK0000_ORGU,0)) THEN 1 ELSE 0 END AS CORE039,
    CASE WHEN NOT (NVL(UAAT,0) + NVL(UAAS,0) + NVL(U1000,0) + NVL(NUAA,0) + NVL(WA,0) + NVL(FA9,0) > 0) THEN 1 ELSE 0 END AS CORE040,
    CASE WHEN NOT (NVL(UAAS,0) = NVL(V0000_S0000S,0) + NVL(N0000S,0) + NVL(ARA09S,0) + NVL(PECRS,0) + NVL(UAA09S,0)) THEN 1 ELSE 0 END AS CORE041,
    CASE WHEN NOT (NVL(UAAT,0) + NVL(UAAS,0) = NVL(OWN_UAA,0) + NVL(RENT_UAA,0) + NVL(SHROTH_UAA,0) + NVL(CMNL_UAA,0)) THEN 1 ELSE 0 END AS CORE042,
    CASE WHEN NOT (NVL(ARAT,0) = NVL(C0000T,0)+NVL(P0000T,0)+NVL(R0000T,0)+NVL(I0000T,0)+NVL(G0000T,0)+NVL(V0000_S0000T,0)+NVL(N0000T,0)+NVL(E0000T,0)+NVL(ARA99T,0)+NVL(Q0000T,0)) THEN 1 ELSE 0 END AS CORE043,
    CASE WHEN NOT (NVL(UAATXK0000_ORG,0) = NVL(ARAT_ORG,0) + NVL(J0000T_ORG,0) + NVL(PECRT_ORG,0)) THEN 1 ELSE 0 END AS CORE044,
    CASE WHEN NOT (NVL(ARAT_ORG,0) >= NVL(C0000T_ORG,0) + NVL(P0000T_ORG,0) + NVL(R0000T_ORG,0) + NVL(I0000T_ORG,0) + NVL(G0000T_ORG,0) + NVL(V0000_S0000T_ORG,0) + NVL(E0000T_ORG,0)) THEN 1 ELSE 0 END AS CORE046,
    CASE WHEN NOT (NVL(C0000T,0) = NVL(C1110T,0) + NVL(C1120T,0) + NVL(C1200T,0) + NVL(C1300T,0) + NVL(C1400T,0) + NVL(C1500T,0) + NVL(C1600T,0) + NVL(C1700T,0) + NVL(C1900T,0) + NVL(C2000T,0)) THEN 1 ELSE 0 END AS CORE047,
    CASE WHEN NOT (NVL(P0000T,0) >= NVL(P1000T,0)) THEN 1 ELSE 0 END AS CORE048,
    CASE WHEN NOT (NVL(R0000T,0) = NVL(R1000T,0) + NVL(R2000T,0) + NVL(R9000T,0)) THEN 1 ELSE 0 END AS CORE049,
    CASE WHEN NOT (NVL(I0000T,0) >= NVL(I1100XI1150T,0)+NVL(I2000T,0)+NVL(I3000T,0)+NVL(I4000T,0)+NVL(I5000T,0)+NVL(I6000T,0)+NVL(I9000T,0)) THEN 1 ELSE 0 END AS CORE050,
    CASE WHEN NOT (NVL(I1100XI1150T,0) = NVL(I1110T,0) + NVL(I1120T,0) + NVL(I1130T,0) + NVL(I1140T,0) + NVL(I1190T,0)) THEN 1 ELSE 0 END AS CORE051,
    CASE WHEN NOT (NVL(I2000T, 0) >= NVL(I2100T,0) + NVL(I2200T,0) + NVL(I1150_2300T,0) + NVL(I2900T,0)) THEN 1 ELSE 0 END AS CORE052,
    CASE WHEN NOT (NVL(V0000_S0000T,0) = NVL(V0000_S0000TO,0)+NVL(V0000_S0000TK,0)) THEN 1 ELSE 0 END AS CORE053,
    CASE WHEN NOT (NVL(G0000T,0) = NVL(G1000T,0) + NVL(G2000T,0) + NVL(G3000T,0) + NVL(G9100T,0) + NVL(G9900T,0)) THEN 1 ELSE 0 END AS CORE054,
    CASE WHEN NOT (NVL(F0000T,0) >= NVL(F1100T,0)+NVL(F1200T,0)+NVL(F2000T,0)+NVL(F3000T,0)+NVL(F4000T,0)) THEN 1 ELSE 0 END AS CORE055,
    CASE WHEN NOT (NVL(W1000T,0) >= NVL(W1100T,0) + NVL(W1200T,0) + NVL(W1300T,0)) THEN 1 ELSE 0 END AS CORE056,
    CASE WHEN NOT (NVL(W1100T,0) >= NVL(W1110T,0) + NVL(W1120T,0) + NVL(W1190T,0)) THEN 1 ELSE 0 END AS CORE057,
    CASE WHEN NOT (NVL(K0000T, 0) <= 1) THEN 1 ELSE 0 END AS CORE058,
    CASE WHEN NOT (NVL(J0000T,0) = NVL(J1000T,0)+NVL(J2000T,0)+NVL(J3000TE,0)) THEN 1 ELSE 0 END AS CORE059,
    CASE WHEN NOT (NVL(PECRT,0) = NVL(F0000T,0)+NVL(T0000T,0)+NVL(W1000T,0)+NVL(O1000T,0)+NVL(PECR9_H9000T,0)+NVL(L0000T,0)) THEN 1 ELSE 0 END AS CORE060,
    CASE WHEN NOT (NVL(WA,0) >= NVL(SRCAA,0)) THEN 1 ELSE 0 END AS CORE061,
    CASE WHEN NOT (NVL(C0000T_ORG,0) <= NVL(C0000T,0)) THEN 1 ELSE 0 END AS CORE062,
    CASE WHEN NOT (NVL(C0000T_ORG,0) >= NVL(C1110T_ORG,0) + NVL(C1120T_ORG,0)) THEN 1 ELSE 0 END AS CORE063,
    CASE WHEN NOT (NVL(P0000T_ORG,0) <= NVL(P0000T,0)) THEN 1 ELSE 0 END AS CORE064,
    CASE WHEN NOT (NVL(R0000T_ORG,0) <= NVL(R0000T,0)) THEN 1 ELSE 0 END AS CORE065,
    CASE WHEN NOT (NVL(R0000T_ORG,0) >= NVL(R1000T_ORG,0) + NVL(R2000T_ORG, 0)) THEN 1 ELSE 0 END AS CORE066,
    CASE WHEN NOT (NVL(R1000T_ORG,0) <= NVL(R1000T,0)) THEN 1 ELSE 0 END AS CORE067,
    CASE WHEN NOT (NVL(R2000T_ORG,0) <= NVL(R2000T,0)) THEN 1 ELSE 0 END AS CORE068,
    CASE WHEN NOT (NVL(I0000T_ORG,0) <= NVL(I0000T,0)) THEN 1 ELSE 0 END AS CORE069,
    CASE WHEN NOT (NVL(I0000T_ORG,0) >= NVL(I1100XI1150T_ORG,0)) THEN 1 ELSE 0 END AS CORE070,
    CASE WHEN NOT (NVL(I1100XI1150T_ORG,0) <= NVL(I1100XI1150T,0)) THEN 1 ELSE 0 END AS CORE071,
    CASE WHEN NOT (NVL(I1100XI1150T_ORG,0) >= NVL(I1130T_ORG,0)) THEN 1 ELSE 0 END AS CORE072,
    CASE WHEN NOT (NVL(G0000T_ORG,0) <= NVL(G0000T,0)) THEN 1 ELSE 0 END AS CORE073,
    CASE WHEN NOT (NVL(G0000T_ORG,0) >= NVL(G1000T_ORG,0) + NVL(G2000T_ORG,0)) THEN 1 ELSE 0 END AS CORE074,
    CASE WHEN NOT (NVL(V0000_S0000T_ORG,0) <= NVL(V0000_S0000T,0)) THEN 1 ELSE 0 END AS CORE075,
    CASE WHEN NOT (NVL(E0000T_ORG,0) <= NVL(E0000T,0)) THEN 1 ELSE 0 END AS CORE076,
    CASE WHEN NOT (NVL(J0000T_ORG,0) <= NVL(J0000T,0)) THEN 1 ELSE 0 END AS CORE077,
    CASE WHEN NOT (NVL(J0000T_ORG,0) >= NVL(J1000T_ORG,0) + NVL(J2000T_ORG,0)) THEN 1 ELSE 0 END AS CORE078,
    CASE WHEN NOT (NVL(J1000T_ORG,0) <= NVL(J1000T,0)) THEN 1 ELSE 0 END AS CORE079,
    CASE WHEN NOT (NVL(J2000T_ORG,0) <= NVL(J2000T,0)) THEN 1 ELSE 0 END AS CORE080,
    CASE WHEN NOT (NVL(PECRT_ORG,0) <= NVL(PECRT,0)) THEN 1 ELSE 0 END AS CORE081,
    CASE WHEN NOT (NVL(PECRT_ORG,0) >= NVL(F0000T_ORG,0) + NVL(T0000T_ORG,0) + NVL(W1100T_ORG,0) + NVL(O1000T_ORG,0)) THEN 1 ELSE 0 END AS CORE082,
    CASE WHEN NOT (NVL(F0000T_ORG,0) <= NVL(F0000T,0)) THEN 1 ELSE 0 END AS CORE083,
    CASE WHEN NOT (NVL(T0000T_ORG,0) <= NVL(T0000T,0)) THEN 1 ELSE 0 END AS CORE084,
    CASE WHEN NOT (NVL(W1100T_ORG,0) <= NVL(W1100T,0)) THEN 1 ELSE 0 END AS CORE085,
    CASE WHEN NOT (NVL(O1000T_ORG,0) <= NVL(O1000T,0)) THEN 1 ELSE 0 END AS CORE086,
    CASE WHEN NOT (NVL(A2000_ORG,0) >= (NVL(A2300F_ORG,0) + NVL(A2300G_ORG,0))) THEN 1 ELSE 0 END AS CORE087,
    CASE WHEN NOT (NVL(A3000_ORG,0) <= NVL(A3110,0) + NVL(A3120,0) + NVL(A3130,0)) THEN 1 ELSE 0 END AS CORE088,
    CASE WHEN NOT (NVL(A4100_ORG,0) <= NVL(A4100,0)) THEN 1 ELSE 0 END AS CORE089,
    CASE WHEN NOT (NVL(A4200_ORG,0) <= NVL(A4200,0)) THEN 1 ELSE 0 END AS CORE090,
    CASE WHEN NOT (NVL(A5000_ORG,0) >= NVL(A5110O_ORG,0) + NVL(A5140_ORG,0)) THEN 1 ELSE 0 END AS CORE091,
    CASE WHEN NOT (NVL(A5110O_ORG,0) <= NVL(A5110O,0)) THEN 1 ELSE 0 END AS CORE092,
    CASE WHEN NOT (NVL(A5140_ORG,0) <= NVL(A5140,0)) THEN 1 ELSE 0 END AS CORE093,
    CASE WHEN NOT (NVL(A2020,0) >= NVL(A2120,0) + NVL(A2220,0)) THEN 1 ELSE 0 END AS CORE094,
    CASE WHEN NOT (NVL(A2300,0) = NVL(A2300F,0) + NVL(A2300G,0)) THEN 1 ELSE 0 END AS CORE095,
    CASE WHEN NOT (NVL(A2410,0) <= NVL(A2300,0)) THEN 1 ELSE 0 END AS CORE096,
    CASE WHEN NOT (NVL(A2230_2300,0) = NVL(A2230,0) + NVL(A2300,0)) THEN 1 ELSE 0 END AS CORE097,
    CASE WHEN NOT (NVL(A4100,0) >= NVL(A4110K,0) + NVL(A4120,0)) THEN 1 ELSE 0 END AS CORE098,
    CASE WHEN NOT (NVL(A4200,0) >= NVL(A4210K,0) + NVL(A4220,0)) THEN 1 ELSE 0 END AS CORE099,
    CASE WHEN NOT (NVL(A5000X5100,0) = NVL(A5210,0) + NVL(A5220,0) + NVL(A5230,0) + NVL(A5410,0) + NVL(A5240_5300,0)) THEN 1 ELSE 0 END AS CORE100,
    CASE WHEN NOT (NVL(UAAT_IB,0) <= NVL(UAAT,0)) THEN 1 ELSE 0 END AS CORE101,
    CASE WHEN (REF_AREA = 'AL') AND NOT (TIME_PERIOD = 2022) THEN 1 ELSE 0 END AS CORE121,
    CASE WHEN (REF_AREA = 'RS') AND NOT (TIME_PERIOD = 2021) THEN 1 ELSE 0 END AS CORE122,
    CASE WHEN (REF_AREA = 'BA') AND NOT (TIME_PERIOD = 2021) THEN 1 ELSE 0 END AS CORE123,
    CASE WHEN (REF_AREA = 'XK') AND NOT (TIME_PERIOD = 2023) THEN 1 ELSE 0 END AS CORE124,
    CASE WHEN (REF_AREA = 'TR') AND NOT (TIME_PERIOD = 2022) THEN 1 ELSE 0 END AS CORE125,
    CASE WHEN (REF_AREA = 'MK') AND NOT (TIME_PERIOD = 2020) THEN 1 ELSE 0 END AS CORE126,
    CASE WHEN NOT (NVL(V0000_S0000T,0) >= NVL(V0000_S0000T_ORG,0)) THEN 1 ELSE 0 END AS CORE129,
    CASE WHEN NOT (NVL(V0000_S0000S,0) >= NVL(V0000_S0000S_ORG,0)) THEN 1 ELSE 0 END AS CORE130,
    CASE WHEN (EXTPOL_FACT2_CORE IS NULL) AND NOT (EXTPOL_FACT3_CORE IS NULL) THEN 1 ELSE 0 END AS CORE131,
    CASE WHEN (EXTPOL_FACT1_CORE IS NOT NULL AND EXTPOL_FACT2_CORE IS NULL AND EXTPOL_FACT3_CORE IS NULL) AND NOT (PSU_CORE IS NULL AND SSU_CORE IS NULL) THEN 1 ELSE 0 END AS CORE132,
    CASE WHEN (EXTPOL_FACT1_CORE IS NOT NULL AND EXTPOL_FACT2_CORE IS NOT NULL AND EXTPOL_FACT3_CORE IS NULL) AND NOT (PSU_CORE IS NOT NULL AND SSU_CORE IS NULL) THEN 1 ELSE 0 END AS CORE133,
    CASE WHEN (EXTPOL_FACT1_CORE IS NOT NULL AND EXTPOL_FACT2_CORE IS NOT NULL AND EXTPOL_FACT3_CORE IS NOT NULL) AND NOT (PSU_CORE IS NOT NULL AND SSU_CORE IS NOT NULL) THEN 1 ELSE 0 END AS CORE134,
    CASE WHEN (STRA_ID_CORE IS NULL) AND NOT (STRA_IDF_CORE = '_Z') THEN 1 ELSE 0 END AS CORE135,
    CASE WHEN (STRA_ID_CORE IS NOT NULL) AND NOT (STRA_IDF_CORE IN ('1','2','3')) THEN 1 ELSE 0 END AS CORE136,
    CASE WHEN (PSU_CORE IS NULL) AND NOT (PSUF_CORE = '_Z') THEN 1 ELSE 0 END AS CORE137,
    CASE WHEN (PSU_CORE IS NOT NULL) AND NOT (PSUF_CORE = '1') THEN 1 ELSE 0 END AS CORE138,
    CASE WHEN (SSU_CORE IS NULL) AND NOT (SSUF_CORE = '_Z') THEN 1 ELSE 0 END AS CORE139,
    CASE WHEN (SSU_CORE IS NOT NULL) AND NOT (SSUF_CORE = '1') THEN 1 ELSE 0 END AS CORE140,
    CASE WHEN (OSU_S1_CORE IS NULL) AND NOT (OSU_SF1_CORE = '_Z') THEN 1 ELSE 0 END AS CORE141,
    CASE WHEN (OSU_S1_CORE IS NOT NULL) AND NOT (OSU_SF1_CORE = '1') THEN 1 ELSE 0 END AS CORE142,

    -- Rekord-pár szabályok (előre kiszámolt analitikus oszlopokból)
    CASE WHEN PSU_CORE IS NOT NULL AND X_CORE_PSU_STRA > 1 THEN 1 ELSE 0 END AS CORE143,
    CASE WHEN SSU_CORE IS NOT NULL AND (X_CORE_SSU_PSU > 1 OR X_CORE_SSU_STRA > 1) THEN 1 ELSE 0 END AS CORE144,

    CASE WHEN NOT (NVL(UAAT, 0) >= NVL(UAATXK0000_ORG,0)) THEN 1 ELSE 0 END AS CORE145,
    CASE WHEN NOT (NVL(ARAT, 0) >= NVL(ARAT_ORG, 0)) THEN 1 ELSE 0 END AS CORE146,
    CASE WHEN NOT (NVL(C1110T, 0) >= NVL(C1110T_ORG, 0)) THEN 1 ELSE 0 END AS CORE147,
    CASE WHEN NOT (NVL(C1120T, 0) >= NVL(C1120T_ORG, 0)) THEN 1 ELSE 0 END AS CORE148,
    CASE WHEN NOT (NVL(I1130T, 0) >= NVL(I1130T_ORG, 0)) THEN 1 ELSE 0 END AS CORE149,
    CASE WHEN NOT (NVL(G1000T, 0) >= NVL(G1000T_ORG, 0)) THEN 1 ELSE 0 END AS CORE150,
    CASE WHEN NOT (NVL(G2000T, 0) >= NVL(G2000T_ORG, 0)) THEN 1 ELSE 0 END AS CORE151,
    CASE WHEN NOT (NVL(J1000T, 0) >= NVL(J1000T_ORG, 0)) THEN 1 ELSE 0 END AS CORE152,
    CASE WHEN NOT (NVL(J2000T, 0) >= NVL(J2000T_ORG, 0)) THEN 1 ELSE 0 END AS CORE153,
    CASE WHEN NOT (NVL(V0000_S0000S, 0) >= NVL(V0000_S0000S_ORG, 0)) THEN 1 ELSE 0 END AS CORE154,
    CASE WHEN NOT (NVL(A2000_ORG, 0) <= NVL(A2010, 0)+NVL(A2020, 0)+NVL(A2230_2300, 0)+NVL(A2130, 0)) THEN 1 ELSE 0 END AS CORE155,
    CASE WHEN NOT (NVL(A5000_ORG, 0) <= NVL(A5110O, 0)+NVL(A5140, 0)+NVL(A5000X5100, 0)) THEN 1 ELSE 0 END AS CORE156,
    CASE WHEN (Y_BIRTH_MAN IS NOT NULL) AND NOT (NVL(Y_BIRTH_MAN, 0) < 2011 OR NVL(Y_BIRTH_MAN, 0) > 1906) THEN 1 ELSE 0 END AS CORE157,
    CASE WHEN (LEG_FORM = 'UNIT_CML' AND Y_BIRTH_MAN IS NOT NULL) AND NOT (SEX_MAN <> '_Z' AND WH_MAN_AWU_PC <> '_Z' AND Y_FARM_MAN IS NOT NULL AND TNG_MAN <>'_Z' AND VT_MAN_M12 <>'_Z') THEN 1 ELSE 0 END AS CORE158,
    CASE WHEN (LEG_FORM = 'UNIT_CML' AND SEX_MAN <> '_Z') AND NOT (Y_BIRTH_MAN IS NOT NULL AND WH_MAN_AWU_PC <> '_Z' AND Y_FARM_MAN IS NOT NULL AND TNG_MAN <>'_Z' AND VT_MAN_M12 <>'_Z') THEN 1 ELSE 0 END AS CORE159,
    CASE WHEN (LEG_FORM = 'UNIT_CML' AND WH_MAN_AWU_PC <> '_Z') AND NOT (Y_BIRTH_MAN IS NOT NULL AND SEX_MAN <> '_Z' AND Y_FARM_MAN IS NOT NULL AND TNG_MAN <>'_Z' AND VT_MAN_M12 <>'_Z') THEN 1 ELSE 0 END AS CORE160,
    CASE WHEN (LEG_FORM = 'UNIT_CML' AND Y_FARM_MAN IS NOT NULL) AND NOT (Y_BIRTH_MAN IS NOT NULL AND SEX_MAN <> '_Z' AND WH_MAN_AWU_PC <>'_Z' AND TNG_MAN <>'_Z' AND VT_MAN_M12 <>'_Z') THEN 1 ELSE 0 END AS CORE161,
    CASE WHEN (LEG_FORM = 'UNIT_CML' AND TNG_MAN <> '_Z') AND NOT (Y_BIRTH_MAN IS NOT NULL AND SEX_MAN <> '_Z' AND WH_MAN_AWU_PC <>'_Z' AND Y_FARM_MAN IS NOT NULL AND VT_MAN_M12 <>'_Z') THEN 1 ELSE 0 END AS CORE162,
    CASE WHEN (LEG_FORM = 'UNIT_CML' AND VT_MAN_M12 <> '_Z') AND NOT (Y_BIRTH_MAN IS NOT NULL AND SEX_MAN <> '_Z' AND WH_MAN_AWU_PC <>'_Z' AND Y_FARM_MAN IS NOT NULL AND TNG_MAN <>'_Z') THEN 1 ELSE 0 END AS CORE163,
    CASE WHEN (UAA_CALC < 5 AND ARA_CALC < 2 AND NVL(R1000T,0) < 0.5 AND NVL(V0000_S0000T,0) < 0.5
        AND (NVL(I5000T,0)+NVL(N0000T,0)+NVL(E0000T,0)+NVL(L0000T,0)) < 0.2
        AND (NVL(F0000T,0)+NVL(T0000T,0)+NVL(PECR9_H9000T,0)) < 0.3
        AND NVL(W1000T,0) < 0.1 AND NVL(O1000T,0) < 0.3
        AND NVL(UAAS,0) < 0.01 AND NVL(U1000,0) < 0.01 AND LIVESTOCK_LSU < 1.7)
        AND NOT (HLD_FEF = 1) THEN 1 ELSE 0 END AS CORE164,
    CASE WHEN NOT (NVL(UAAXK0000_ORGF, 0) + NVL(UAAXK0000_ORGU, 0) >= NVL(UAATXK0000_ORG, 0) + NVL(V0000_S0000S_ORG, 0)) THEN 1 ELSE 0 END AS CORE165,
    CASE WHEN NOT (NVL(UAAT,0) - NVL(UAAS,0) - NVL(K0000T,0) >= NVL(UAAXK0000_ORGF,0) + NVL(UAAXK0000_ORGU,0)) THEN 1 ELSE 0 END AS CORE166,
    CASE WHEN (ORG = 0) AND NOT ((NVL(UAAXK0000_ORGF, 0) + NVL(UAAXK0000_ORGU, 0)) = 0 AND (NVL(A2000_ORG, 0) + NVL(A3000_ORG, 0) + NVL(A4100_ORG, 0) + NVL(A4200_ORG, 0) + NVL(A5000_ORG, 0)) = 0) THEN 1 ELSE 0 END AS CORE167,
    CASE WHEN (ORG = 1) AND NOT ((NVL(UAAXK0000_ORGF, 0) + NVL(UAAXK0000_ORGU, 0)) > 0 OR (NVL(A2000_ORG, 0) + NVL(A3000_ORG, 0) + NVL(A4100_ORG, 0) + NVL(A4200_ORG, 0) + NVL(A5000_ORG, 0)) > 0) THEN 1 ELSE 0 END AS CORE168,

    -- ===== LAFO =====
    CASE WHEN (EXTPOL_FACT1_LAFO IS NOT NULL) AND NOT (NVL(EXTPOL_FACT1_LAFO, 0) >= NVL(EXTPOL_FACT1_CORE, 0)) THEN 1 ELSE 0 END AS LAFO001,
    CASE WHEN (EXTPOL_FACT1_LAFO IS NOT NULL AND STRA_ID_CORE IS NOT NULL) AND NOT (NVL(STRA_ID_LAFO, 0) = NVL(STRA_ID_CORE, 0)) THEN 1 ELSE 0 END AS LAFO002,
    CASE WHEN (EXTPOL_FACT2_LAFO IS NOT NULL AND PSU_CORE IS NOT NULL) AND NOT (NVL(PSU_LAFO, 0) = NVL(PSU_CORE, 0)) THEN 1 ELSE 0 END AS LAFO003,
    CASE WHEN (EXTPOL_FACT3_LAFO IS NOT NULL AND SSU_CORE IS NOT NULL) AND NOT (NVL(SSU_LAFO, 0) = NVL(SSU_CORE, 0)) THEN 1 ELSE 0 END AS LAFO004,
    CASE WHEN (EXTPOL_FACT1_LAFO IS NOT NULL AND OSU_S1_CORE IS NOT NULL) AND NOT (NVL(OSU_S1_LAFO, 0) = NVL(OSU_S1_CORE, 0)) THEN 1 ELSE 0 END AS LAFO005,
    CASE WHEN (EXTPOL_FACT1_LAFO IS NOT NULL AND LEG_FORM IN ('PER_LEG_NEG','PER_LEG_EG','UNIT_CML')) AND NOT (SEX_HLD = '_Z') THEN 1 ELSE 0 END AS LAFO007,
    CASE WHEN (EXTPOL_FACT1_LAFO IS NOT NULL AND LEG_FORM NOT IN ('PER_LEG_NEG','PER_LEG_EG','UNIT_CML')) AND NOT (SEX_HLD IN ('M', 'F')) THEN 1 ELSE 0 END AS LAFO008,
    CASE WHEN (EXTPOL_FACT1_LAFO IS NOT NULL AND LEG_FORM IN ('FARM_HLD','HLD_GRP')) AND NOT (SEX_MAN = SEX_HLD) THEN 1 ELSE 0 END AS LAFO009,
    CASE WHEN (EXTPOL_FACT1_LAFO IS NOT NULL AND LEG_FORM IN ('PER_LEG_NEG','PER_LEG_EG','UNIT_CML')) AND NOT (Y_BIRTH_HLD IS NULL) THEN 1 ELSE 0 END AS LAFO010,
    CASE WHEN (EXTPOL_FACT1_LAFO IS NOT NULL AND LEG_FORM NOT IN ('PER_LEG_NEG','PER_LEG_EG','UNIT_CML')) AND NOT (Y_BIRTH_HLD IS NOT NULL) THEN 1 ELSE 0 END AS LAFO011,
