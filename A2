    CASE WHEN (EXTPOL_FACT3_AHMM IS NOT NULL AND SSU_CORE IS NOT NULL) AND NOT (NVL(SSU_AHMM, 0) = NVL(SSU_CORE, 0)) THEN 1 ELSE 0 END AS AHMM005,
    CASE WHEN (EXTPOL_FACT1_AHMM IS NOT NULL AND OSU_S1_CORE IS NOT NULL) AND NOT (NVL(OSU_S1_AHMM, 0) = NVL(OSU_S1_CORE, 0)) THEN 1 ELSE 0 END AS AHMM006,
    CASE WHEN (EXTPOL_FACT1_AHMM IS NOT NULL AND NVL(UAA_FER_M, 0) > 0) AND NOT (NVL(UAA_FER_M, 0) <= NVL(UAAT, 0) + NVL(UAAS, 0)) THEN 1 ELSE 0 END AS AHMM007,
    CASE WHEN (EXTPOL_FACT1_AHMM IS NOT NULL AND NVL(UAA_FER_O_LM, 0) > 0) AND NOT (NVL(UAA_FER_O_LM, 0) <= NVL(UAAT, 0) + NVL(UAAS, 0)) THEN 1 ELSE 0 END AS AHMM008,
    CASE WHEN (EXTPOL_FACT1_AHMM IS NOT NULL AND (NVL(UAA_FER_M, 0) > 0 OR NVL(UAA_FER_O_LM, 0) > 0)) AND NOT (NVL(UAA_FER_M,0) + NVL(UAA_FER_O_LM,0) <= NVL(UAAT,0) + NVL(UAAS,0)) THEN 1 ELSE 0 END AS AHMM009,
    CASE WHEN EXTPOL_FACT1_AHMM IS NOT NULL AND NOT (NVL(INC_BC_LE4H_NUM,0) + NVL(INC_BC_GT4H_NUM,0) + NVL(NINC_BC_NUM,0) + NVL(INC_BSTH_NUM,0) + NVL(INC_BSTS_NUM,0) + NVL(INJ_SOL_NUM,0) + NVL(INJ_DPCL_NUM,0) <= 100) THEN 1 ELSE 0 END AS AHMM017,
    CASE WHEN EXTPOL_FACT1_AHMM IS NOT NULL AND NOT (NVL(ST_SO_HEAP,0)+NVL(ST_COMP,0)+NVL(ST_PIT,0)+NVL(ST_DPLT,0)+NVL(ST_LQ_SL_NC,0)+NVL(ST_LQ_SL_PC,0)+NVL(ST_LQ_SL_IC,0)+NVL(ST_OF,0)+NVL(NST_DSPR,0) <= 100) THEN 1 ELSE 0 END AS AHMM018,
    CASE WHEN (EXTPOL_FACT1_AHMM IS NOT NULL AND (NVL(ST_SO_HEAP, 0)+NVL(ST_COMP, 0)+NVL(ST_PIT, 0)+NVL(ST_DPLT, 0)+NVL(ST_LQ_SL_NC, 0)+NVL(ST_LQ_SL_PC, 0)+NVL(ST_LQ_SL_IC, 0)+NVL(ST_OF, 0)+NVL(NST_DSPR, 0)) < 100) AND NOT ((NVL(NETEXP_FER_O_LM_LQ_SL, 0) > 0) OR (NVL(NETEXP_FER_O_LM_SO, 0) > 0)) THEN 1 ELSE 0 END AS AHMM019,
    CASE WHEN EXTPOL_FACT1_AHMM IS NULL
        AND (UAA_FER_M IS NOT NULL OR UAA_FER_O_LM IS NOT NULL OR FER_O_XLM IS NOT NULL
             OR INC_BC_LE4H_PC IS NOT NULL OR INC_BC_GT4H_PC IS NOT NULL OR NINC_BC_PC IS NOT NULL
             OR INC_BSTH_PC IS NOT NULL OR INC_BSTS_PC IS NOT NULL OR INJ_SOL_PC IS NOT NULL OR INJ_DPCL_PC IS NOT NULL
             OR ST_SO_HEAP IS NOT NULL OR ST_COMP IS NOT NULL OR ST_PIT IS NOT NULL OR ST_DPLT IS NOT NULL
             OR ST_LQ_SL_NC IS NOT NULL OR ST_LQ_SL_PC IS NOT NULL OR ST_LQ_SL_IC IS NOT NULL OR ST_OF IS NOT NULL
             OR NST_DSPR IS NOT NULL OR NETEXP_FER_O_LM_LQ_SL IS NOT NULL OR NETEXP_FER_O_LM_SO IS NOT NULL
             OR STRA_IDF_AHMM <> '_Z' OR PSUF_AHMM <> '_Z' OR SSUF_AHMM <> '_Z' OR OSU_SF1_AHMM <> '_Z')
        THEN 1 ELSE 0 END AS AHMM020,
    CASE WHEN (EXTPOL_FACT2_AHMM IS NULL) AND NOT (EXTPOL_FACT3_AHMM IS NULL) THEN 1 ELSE 0 END AS AHMM021,
    CASE WHEN EXTPOL_FACT1_AHMM IS NULL
        AND (UAA_FER_M IS NOT NULL OR UAA_FER_O_LM IS NOT NULL OR ST_SO_HEAP IS NOT NULL OR ST_COMP IS NOT NULL
             OR STRA_IDF_AHMM <> '_Z' OR PSUF_AHMM <> '_Z' OR SSUF_AHMM <> '_Z' OR OSU_SF1_AHMM <> '_Z')
        THEN 1 ELSE 0 END AS AHMM022,
    CASE WHEN (EXTPOL_FACT2_AHMM IS NOT NULL) AND NOT (NVL(EXTPOL_FACT2_AHMM, 0) >= NVL(EXTPOL_FACT2_CORE, 0)) THEN 1 ELSE 0 END AS AHMM024,
    CASE WHEN (EXTPOL_FACT3_AHMM IS NOT NULL) AND NOT (NVL(EXTPOL_FACT3_AHMM, 0) >= NVL(EXTPOL_FACT3_CORE, 0)) THEN 1 ELSE 0 END AS AHMM025,
    CASE WHEN (EXTPOL_FACT1_AHMM IS NOT NULL AND EXTPOL_FACT2_AHMM IS NULL AND EXTPOL_FACT3_AHMM IS NULL) AND NOT (PSU_AHMM IS NULL AND SSU_AHMM IS NULL) THEN 1 ELSE 0 END AS AHMM026,
    CASE WHEN (EXTPOL_FACT1_AHMM IS NOT NULL AND EXTPOL_FACT2_AHMM IS NOT NULL AND EXTPOL_FACT3_AHMM IS NULL) AND NOT (PSU_AHMM IS NOT NULL AND SSU_AHMM IS NULL) THEN 1 ELSE 0 END AS AHMM027,
    CASE WHEN (EXTPOL_FACT1_AHMM IS NOT NULL AND EXTPOL_FACT2_AHMM IS NOT NULL AND EXTPOL_FACT3_AHMM IS NOT NULL) AND NOT (PSU_AHMM IS NOT NULL AND SSU_AHMM IS NOT NULL) THEN 1 ELSE 0 END AS AHMM028,
    CASE WHEN (STRA_ID_AHMM IS NULL) AND NOT (STRA_IDF_AHMM = '_Z') THEN 1 ELSE 0 END AS AHMM029,
    CASE WHEN (STRA_ID_AHMM IS NOT NULL) AND NOT (STRA_IDF_AHMM IN ('1','2','3')) THEN 1 ELSE 0 END AS AHMM030,
    CASE WHEN (PSU_AHMM IS NULL) AND NOT (PSUF_AHMM = '_Z') THEN 1 ELSE 0 END AS AHMM031,
    CASE WHEN (PSU_AHMM IS NOT NULL) AND NOT (PSUF_AHMM = '1') THEN 1 ELSE 0 END AS AHMM032,
    CASE WHEN (SSU_AHMM IS NULL) AND NOT (SSUF_AHMM = '_Z') THEN 1 ELSE 0 END AS AHMM033,
    CASE WHEN (SSU_AHMM IS NOT NULL) AND NOT (SSUF_AHMM = '1') THEN 1 ELSE 0 END AS AHMM034,
    CASE WHEN (OSU_S1_AHMM IS NULL) AND NOT (OSU_SF1_AHMM = '_Z') THEN 1 ELSE 0 END AS AHMM035,
    CASE WHEN (OSU_S1_AHMM IS NOT NULL) AND NOT (OSU_SF1_AHMM = '1') THEN 1 ELSE 0 END AS AHMM036,

    CASE WHEN PSU_AHMM IS NOT NULL AND X_AHMM_PSU_STRA > 1 THEN 1 ELSE 0 END AS AHMM037,
    CASE WHEN SSU_AHMM IS NOT NULL AND (X_AHMM_SSU_PSU > 1 OR X_AHMM_SSU_STRA > 1) THEN 1 ELSE 0 END AS AHMM038,

    CASE WHEN (EXTPOL_FACT1_AHMM IS NULL) AND NOT (EXTPOL_FACT2_AHMM IS NULL AND EXTPOL_FACT3_AHMM IS NULL) THEN 1 ELSE 0 END AS AHMM039,
    CASE WHEN EXTPOL_FACT1_AHMM IS NOT NULL
        AND (UAA_FER_M IS NULL OR UAA_FER_O_LM IS NULL OR ST_SO_HEAP IS NULL OR ST_COMP IS NULL)
        THEN 1 ELSE 0 END AS AHMM040,

    -- ===== VINY =====
    CASE WHEN (EXTPOL_FACT1_VINY IS NOT NULL) AND NOT (NVL(EXTPOL_FACT1_VINY, 0) >= NVL(EXTPOL_FACT1_CORE, 0)) THEN 1 ELSE 0 END AS VINY001,
    CASE WHEN (EXTPOL_FACT1_VINY IS NOT NULL AND STRA_ID_CORE IS NOT NULL) AND NOT (NVL(STRA_ID_VINY, 0) = NVL(STRA_ID_CORE, 0)) THEN 1 ELSE 0 END AS VINY002,
    CASE WHEN (EXTPOL_FACT2_VINY IS NOT NULL AND PSU_CORE IS NOT NULL) AND NOT (NVL(PSU_VINY, 0) = NVL(PSU_CORE, 0)) THEN 1 ELSE 0 END AS VINY003,
    CASE WHEN (EXTPOL_FACT3_VINY IS NOT NULL AND SSU_CORE IS NOT NULL) AND NOT (NVL(SSU_VINY, 0) = NVL(SSU_CORE, 0)) THEN 1 ELSE 0 END AS VINY004,
    CASE WHEN (EXTPOL_FACT1_VINY IS NOT NULL AND OSU_S1_CORE IS NOT NULL) AND NOT (NVL(OSU_S1_VINY, 0) = NVL(OSU_S1_CORE, 0)) THEN 1 ELSE 0 END AS VINY005,
    CASE WHEN EXTPOL_FACT1_VINY IS NULL
        AND (TIME_PERIOD_VINY IS NOT NULL OR W1100 IS NOT NULL OR W1100_Y_LT3 IS NOT NULL
             OR W1100_Y_3T9 IS NOT NULL OR W1100_Y_10T19 IS NOT NULL OR W1100_Y_20T29 IS NOT NULL
             OR W1100_Y_GE30 IS NOT NULL OR WINE_VAR_NR IS NOT NULL
             OR STRA_IDF_VINY <> '_Z' OR PSUF_VINY <> '_Z' OR SSUF_VINY <> '_Z' OR OSU_SF1_VINY <> '_Z')
        THEN 1 ELSE 0 END AS VINY006,
    CASE WHEN (EXTPOL_FACT2_VINY IS NULL) AND NOT (EXTPOL_FACT3_VINY IS NULL) THEN 1 ELSE 0 END AS VINY007,
    CASE WHEN (W1100 IS NOT NULL OR WINE_VAR_NR IS NOT NULL) AND EXTPOL_FACT1_VINY IS NULL THEN 1 ELSE 0 END AS VINY008,
    CASE WHEN (EXTPOL_FACT2_VINY IS NOT NULL) AND NOT (NVL(EXTPOL_FACT2_VINY, 0) >= NVL(EXTPOL_FACT2_CORE, 0)) THEN 1 ELSE 0 END AS VINY009,
    CASE WHEN (EXTPOL_FACT3_VINY IS NOT NULL) AND NOT (NVL(EXTPOL_FACT3_VINY, 0) >= NVL(EXTPOL_FACT3_CORE, 0)) THEN 1 ELSE 0 END AS VINY010,
    CASE WHEN (EXTPOL_FACT1_VINY IS NOT NULL AND EXTPOL_FACT2_VINY IS NULL AND EXTPOL_FACT3_VINY IS NULL) AND NOT (PSU_VINY IS NULL AND SSU_VINY IS NULL) THEN 1 ELSE 0 END AS VINY011,
    CASE WHEN (EXTPOL_FACT1_VINY IS NOT NULL AND EXTPOL_FACT2_VINY IS NOT NULL AND EXTPOL_FACT3_VINY IS NULL) AND NOT (PSU_VINY IS NOT NULL AND SSU_VINY IS NULL) THEN 1 ELSE 0 END AS VINY012,
    CASE WHEN (EXTPOL_FACT1_VINY IS NOT NULL AND EXTPOL_FACT2_VINY IS NOT NULL AND EXTPOL_FACT3_VINY IS NOT NULL) AND NOT (PSU_VINY IS NOT NULL AND SSU_VINY IS NOT NULL) THEN 1 ELSE 0 END AS VINY013,
    CASE WHEN (STRA_ID_VINY IS NULL) AND NOT (STRA_IDF_VINY = '_Z') THEN 1 ELSE 0 END AS VINY014,
    CASE WHEN (STRA_ID_VINY IS NOT NULL) AND NOT (STRA_IDF_VINY IN ('1','2','3')) THEN 1 ELSE 0 END AS VINY015,
    CASE WHEN (PSU_VINY IS NULL) AND NOT (PSUF_VINY = '_Z') THEN 1 ELSE 0 END AS VINY016,
    CASE WHEN (PSU_VINY IS NOT NULL) AND NOT (PSUF_VINY = '1') THEN 1 ELSE 0 END AS VINY017,
    CASE WHEN (SSU_VINY IS NULL) AND NOT (SSUF_VINY = '_Z') THEN 1 ELSE 0 END AS VINY018,
    CASE WHEN (SSU_VINY IS NOT NULL) AND NOT (SSUF_VINY = '1') THEN 1 ELSE 0 END AS VINY019,
    CASE WHEN (OSU_S1_VINY IS NULL) AND NOT (OSU_SF1_VINY = '_Z') THEN 1 ELSE 0 END AS VINY020,
    CASE WHEN (OSU_S1_VINY IS NOT NULL) AND NOT (OSU_SF1_VINY = '1') THEN 1 ELSE 0 END AS VINY021,

    CASE WHEN PSU_VINY IS NOT NULL AND X_VINY_PSU_STRA > 1 THEN 1 ELSE 0 END AS VINY022,
    CASE WHEN SSU_VINY IS NOT NULL AND (X_VINY_SSU_PSU > 1 OR X_VINY_SSU_STRA > 1) THEN 1 ELSE 0 END AS VINY023,

    CASE WHEN (EXTPOL_FACT1_VINY IS NULL) AND NOT (EXTPOL_FACT2_VINY IS NULL AND EXTPOL_FACT3_VINY IS NULL) THEN 1 ELSE 0 END AS VINY024,
    CASE WHEN NOT (NVL(W1100,0) >= NVL(W1100_Y_LT3,0)+NVL(W1100_Y_3T9,0)+NVL(W1100_Y_10T19,0)+NVL(W1100_Y_20T29,0)+NVL(W1100_Y_GE30,0)) THEN 1 ELSE 0 END AS VINY025,
    CASE WHEN NVL(TIME_PERIOD,0) = NVL(TIME_PERIOD_VINY,0) AND NOT (NVL(W1100,0) >= NVL(W1100T,0)) THEN 1 ELSE 0 END AS VINY026,
    CASE WHEN NVL(TIME_PERIOD,0) <> NVL(TIME_PERIOD_VINY,0) AND NOT (NVL(W1100,0) >= NVL(W1100T,0)) THEN 1 ELSE 0 END AS VINY027,
    CASE WHEN VIN_CNT IS NOT NULL AND VIN_CNT <> WINE_VAR_NR THEN 1 ELSE 0 END AS VINY029,
    CASE WHEN (EXTPOL_FACT1_VINY IS NOT NULL AND NVL(TIME_PERIOD, 0) <> NVL(TIME_PERIOD_VINY, 0)) AND NOT (TIME_PERIOD_VINY = 2025 OR TIME_PERIOD_VINY = 2026) THEN 1 ELSE 0 END AS VINY030

FROM (
    -- ===== KÖZTES ANALITIKUS RÉTEG =====
    -- Itt számoljuk ki előre a csoport-szintű értékeket, hogy a fenti
    -- CASE WHEN oszlopok soronkénti kifejezésként hivatkozhassanak rájuk.
    SELECT b.*,
           COUNT(*) OVER (PARTITION BY b.HLD_ID) AS HLD_CNT,

           COUNT(DISTINCT b.STRA_ID_CORE) OVER (PARTITION BY b.PSU_CORE) AS X_CORE_PSU_STRA,
           COUNT(DISTINCT b.PSU_CORE)     OVER (PARTITION BY b.SSU_CORE) AS X_CORE_SSU_PSU,
           COUNT(DISTINCT b.STRA_ID_CORE) OVER (PARTITION BY b.SSU_CORE) AS X_CORE_SSU_STRA,

           COUNT(DISTINCT b.STRA_ID_LAFO) OVER (PARTITION BY b.PSU_LAFO) AS X_LAFO_PSU_STRA,
           COUNT(DISTINCT b.PSU_LAFO)     OVER (PARTITION BY b.SSU_LAFO) AS X_LAFO_SSU_PSU,
           COUNT(DISTINCT b.STRA_ID_LAFO) OVER (PARTITION BY b.SSU_LAFO) AS X_LAFO_SSU_STRA,

           COUNT(DISTINCT b.STRA_ID_RDEV) OVER (PARTITION BY b.PSU_RDEV) AS X_RDEV_PSU_STRA,
           COUNT(DISTINCT b.PSU_RDEV)     OVER (PARTITION BY b.SSU_RDEV) AS X_RDEV_SSU_PSU,
           COUNT(DISTINCT b.STRA_ID_RDEV) OVER (PARTITION BY b.SSU_RDEV) AS X_RDEV_SSU_STRA,

           COUNT(DISTINCT b.STRA_ID_AHMM) OVER (PARTITION BY b.PSU_AHMM) AS X_AHMM_PSU_STRA,
           COUNT(DISTINCT b.PSU_AHMM)     OVER (PARTITION BY b.SSU_AHMM) AS X_AHMM_SSU_PSU,
           COUNT(DISTINCT b.STRA_ID_AHMM) OVER (PARTITION BY b.SSU_AHMM) AS X_AHMM_SSU_STRA,

           COUNT(DISTINCT b.STRA_ID_VINY) OVER (PARTITION BY b.PSU_VINY) AS X_VINY_PSU_STRA,
           COUNT(DISTINCT b.PSU_VINY)     OVER (PARTITION BY b.SSU_VINY) AS X_VINY_SSU_PSU,
           COUNT(DISTINCT b.STRA_ID_VINY) OVER (PARTITION BY b.SSU_VINY) AS X_VINY_SSU_STRA,

           v.VIN_CNT
    FROM VW_BASE_ENRICHED b
    LEFT JOIN (
        SELECT HLD_ID, COUNT(*) AS VIN_CNT
        FROM "MO26E"."VIN2026"
        WHERE HLD_ID IS NOT NULL
        GROUP BY HLD_ID
    ) v ON v.HLD_ID = b.HLD_ID
);